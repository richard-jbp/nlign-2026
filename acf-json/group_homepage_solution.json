{
	"key": "group_homepage_solution",
	"title": "Homepage — The Solution",
	"fields": [
		{ "key": "field_solution_eyebrow", "label": "Eyebrow", "name": "solution_eyebrow", "type": "text", "default_value": "The Solution" },
		{ "key": "field_solution_title",   "label": "Title",   "name": "solution_title",   "type": "text", "default_value": "A single, trusted view of operational reality." },
		{ "key": "field_solution_lead",    "label": "Lead",    "name": "solution_lead",    "type": "textarea", "rows": 3, "default_value": "NLign unifies asset data across the lifecycle, so teams can align, act, and deliver with confidence." },
		{
			"key": "field_solution_cta", "label": "CTA link", "name": "solution_cta", "type": "group",
			"sub_fields": [
				{ "key": "field_solution_cta_label", "label": "Label", "name": "label", "type": "text", "default_value": "Watch the Demo" },
				{ "key": "field_solution_cta_url",   "label": "URL",   "name": "url",   "type": "url",  "default_value": "#watch" }
			]
		},
		{
			"key": "field_solution_screens", "label": "Dashboard screens (up to 3)", "name": "solution_screens", "type": "gallery",
			"return_format": "array", "min": 0, "max": 3,
			"instructions": "Upload 1–3 dashboard screenshots. They will be stacked diagonally."
		},
		{
			"key": "field_solution_tabs", "label": "Persona tabs", "name": "solution_tabs", "type": "repeater",
			"min": 0, "max": 6, "layout": "block", "button_label": "Add tab",
			"sub_fields": [
				{ "key": "field_solution_t_label", "label": "Label", "name": "label", "type": "text", "required": 1 },
				{ "key": "field_solution_t_slug",  "label": "Slug",  "name": "slug",  "type": "text", "required": 1, "instructions": "URL-safe id, e.g. production" },
				{ "key": "field_solution_t_panel", "label": "Panel content", "name": "panel_content", "type": "wysiwyg", "tabs": "visual", "media_upload": 0 }
			]
		}
	],
	"location": [ [ { "param": "page_type", "operator": "==", "value": "front_page" } ] ],
	"menu_order": 20,
	"active": true
}
